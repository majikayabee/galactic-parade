  "opening": [
    {
      "id": 1,
      "title": "Cut 1 宇宙導入",
      "duration": 5,
      "text": "宇宙最大の移動遊園船団\nギャラクティック・パレード",
      "visual": "宇宙と遠景の船団シルエット",
      "skippable": true
    },
    {
      "id": 2,
      "title": "Cut 2 祝祭の外観",
      "duration": 5,
      "text": "星々を巡り、\n光と音と夢を届ける、銀河の祝祭。",
      "visual": "観覧車、ネオン、光路",
      "skippable": true
    },
    {
      "id": 3,
      "title": "Cut 3 平和なショー",
      "duration": 5,
      "text": "すべては、笑顔のために。",
      "visual": "可愛いマスコットと花火",
      "skippable": true
    },
    {
      "id": 4,
      "title": "Cut 4 異変",
      "duration": 5,
      "text": "だが今、そのショーは暴走し、\n狂騒の舞台へと変わった。",
      "visual": "ノイズ、警告灯、グリッチ",
      "skippable": true
    },
    {
      "id": 5,
      "title": "Cut 5 脅威の提示",
      "duration": 5,
      "text": "マスコット兵器、ショー制御AI、巨大ボス群を突破し、\n船団中枢“ハートゼロ”を停止せよ。",
      "visual": "ボス影、敵弾、危険演出",
      "skippable": true
    },
    {
      "id": 6,
      "title": "Cut 6 ヒカリ",
      "duration": 5,
      "text": "保安隊の若きパイロット、ヒカリ。\n最後の出撃が始まる。",
      "visual": "格納庫、主人公機、ヒカリの横顔",
      "skippable": true
    },
    {
      "id": 7,
      "title": "Cut 7 発進",
      "duration": 3,
      "text": "終わらないパレードに、幕を下ろせ。",
      "visual": "カタパルト射出",
      "skippable": true
    },
    {
      "id": 8,
      "title": "Cut 8 ロゴ",
      "duration": 2,
      "text": "GALACTIC PARADE",
      "visual": "ロゴとサブコピー",
      "skippable": true
    }
  ],
  "text": {
    "titleJa": "ギャラクティック・パレード",
    "titleEn": "GALACTIC PARADE",
    "mainText": "宇宙最大の移動遊園船団\nギャラクティック・パレードが暴走した。\n\nマスコット兵器、ショー制御AI、巨大ボス群を突破し、\n船団中枢“ハートゼロ”を停止せよ。",
    "tagline1": "Beyond the smile, the parade has gone mad.",
    "tagline2": "Stop the endless parade.",
    "storeLine": "暴走した宇宙遊園船団を舞台にした、ポップで過激な弾幕シューティング。",
    "heartZeroFormal": "大演出制御核 ハートゼロ"
  }
}